{
    "name": "typehead",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "pnpm --parallel --filter \"./backend\" --filter \"./frontend\" dev",
        "build": "pnpm -r build",
        "start": "pnpm -r start",
        "seed": "pnpm --filter @typehead/backend seed",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\" --ignore-path .gitignore"
    },
    "packageManager": "pnpm@9.0.0",
    "devDependencies": {
        "prettier": "^3.8.4"
    }
}
